# News sources
NEWSDATA_API_KEY=
GUARDIAN_API_KEY=

# 0G Compute
# The server supports either ZERO_G_* or OG_COMPUTE_* names.
OG_RPC_URL=https://evmrpc.0g.ai
OG_COMPUTE_PROVIDER=
ZERO_G_API_KEY=
ZERO_G_MODEL=zai-org/GLM-5-FP8
OG_COMPUTE_API_KEY=
OG_COMPUTE_MODEL=zai-org/GLM-5-FP8

# Optional: route thread review to a separate, stronger 0G model/provider.
THREAD_OG_COMPUTE_PROVIDER=
THREAD_OG_COMPUTE_ENDPOINT=
THREAD_OG_COMPUTE_API_KEY=
THREAD_OG_COMPUTE_MODEL=deepseek-v4-flash

# Shelby archive
# Shelby's free developer prototype network is `shelbynet`.
# Use the SDK config below for direct Shelby uploads.
SHELBY_NETWORK=SHELBYNET
SHELBY_RPC_URL=https://api.shelbynet.shelby.xyz/shelby
SHELBY_ARCHIVE_PREFIX=siftle/feeds
SHELBY_RETENTION_DAYS=365
SHELBY_PRIVATE_KEY=
SHELBY_ACCOUNT_ADDRESS=
SHELBY_API_KEY=

# Optional only if you build a custom upload proxy. Do not put the Shelby RPC URL here.
SHELBY_UPLOAD_URL=

# Local server
PORT=5173
MAX_ARTICLE_AGE_HOURS=72
REFRESH_INTERVAL_MINUTES=60
THREAD_REVIEW_TIMEOUT_MS=90000
THREAD_PREP_CONCURRENCY=1
THREAD_REVIEW_CANDIDATE_LIMIT=5
THREAD_REVIEW_SAME_DAY_CANDIDATE_LIMIT=1
THREAD_REVIEW_CANDIDATES_PER_DAY=3

# Arc Testnet prediction markets
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# Public browser project ID from https://cloud.reown.com/
REOWN_PROJECT_ID=
SIFTLE_MARKET_FACTORY_ADDRESS=
SIFTLE_MARKET_NEW_GLENN_ADDRESS=
SIFTLE_MARKET_STRATEGY_BTC_SALE_ADDRESS=
SIFTLE_MARKET_NBA_FINALS_ADDRESS=
SIFTLE_MARKET_RESOLVER=
# Deployment secret only. Never expose this through client config or commit it.
ARC_DEPLOYER_PRIVATE_KEY=

# Circle Programmable Wallets (User-Controlled)
# Public App ID (exposed to frontend client-config)
CIRCLE_APP_ID=
# Developer API Key (backend only)
CIRCLE_API_KEY=

# SMTP Mail Server for Email OTP Delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Siftle Auth <no-reply@siftle.xyz>

